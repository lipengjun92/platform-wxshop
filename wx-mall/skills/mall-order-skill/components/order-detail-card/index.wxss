.order-detail-card { padding: 24rpx; background: #fff; border-radius: 12rpx; }
.head { display: flex; justify-content: space-between; align-items: center; font-size: 24rpx; color: #666; }
.status { color: #b4282d; font-weight: bold; }
.address { margin-top: 16rpx; padding: 12rpx; background: #fafafa; border-radius: 8rpx; font-size: 24rpx; color: #333; }
.line { display: flex; padding: 4rpx 0; }
.label { color: #999; width: 130rpx; flex-shrink: 0; }
.goods { margin-top: 16rpx; }
.goods-row { display: flex; align-items: center; padding: 8rpx 0; }
.goods-pic { width: 80rpx; height: 80rpx; border-radius: 6rpx; background: #f7f7f7; }
.goods-info { flex: 1; margin-left: 16rpx; }
.goods-name { font-size: 26rpx; color: #333; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.goods-meta { display: flex; justify-content: space-between; margin-top: 6rpx; font-size: 22rpx; color: #999; }
.goods-price { color: #b4282d; }
.amount { margin-top: 12rpx; padding-top: 12rpx; border-top: 1rpx solid #f2f2f2; font-size: 24rpx; }
.amount .line { justify-content: space-between; color: #666; }
.amount .total { font-size: 28rpx; color: #b4282d; font-weight: bold; }
.action { margin-top: 14rpx; color: #b4282d; font-size: 24rpx; text-align: right; }

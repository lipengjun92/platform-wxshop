.goods-list-card {
  padding: 16rpx;
  background: #fff;
  border-radius: 12rpx;
}
.goods-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f2f2f2;
}
.goods-item:last-child {
  border-bottom: none;
}
.goods-pic {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #f7f7f7;
}
.goods-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.goods-name {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.goods-brief {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}
.goods-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.goods-price {
  color: #b4282d;
  font-size: 30rpx;
  font-weight: bold;
}
.goods-sales {
  color: #999;
  font-size: 22rpx;
}
.empty {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 40rpx 0;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2430;
  margin-bottom: 20rpx;
}

.detail-wrap {
  display: flex;
}

.goods-image {
  width: 188rpx;
  height: 188rpx;
  border-radius: 20rpx;
  background: #f4f6fb;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  min-width: 0;
  padding-left: 20rpx;
}

.goods-name {
  font-size: 28rpx;
  line-height: 1.5;
  color: #1f2430;
  font-weight: 600;
}

.goods-brief {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #68707f;
}

.goods-meta {
  margin-top: 18rpx;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  column-gap: 16rpx;
}

.goods-price-wrap {
  display: flex;
  align-items: baseline;
  min-width: 0;
}

.goods-price {
  color: #e74a3b;
  font-size: 32rpx;
  font-weight: 600;
}

.goods-market {
  margin-left: 16rpx;
  color: #8a92a3;
  text-decoration: line-through;
  font-size: 24rpx;
}

.goods-extra {
  font-size: 22rpx;
  line-height: 1.5;
  color: #68707f;
  white-space: nowrap;
  flex-shrink: 0;
}

.goods-extra text {
  margin-left: 20rpx;
}
.goods-detail-card {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}
.banner {
  width: 100%;
  height: 360rpx;
  background: #f7f7f7;
}
.body {
  padding: 20rpx 24rpx;
}
.name {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  line-height: 1.4;
}
.brief {
  margin-top: 8rpx;
  color: #999;
  font-size: 24rpx;
}
.price-row {
  margin-top: 16rpx;
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}
.retail {
  color: #b4282d;
  font-size: 34rpx;
  font-weight: bold;
}
.market {
  color: #999;
  font-size: 24rpx;
  text-decoration: line-through;
}
.sales {
  margin-left: auto;
  color: #999;
  font-size: 22rpx;
}
.sku-tip {
  margin-top: 14rpx;
  color: #666;
  font-size: 24rpx;
}
.action {
  margin-top: 14rpx;
  color: #b4282d;
  font-size: 24rpx;
}

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.platform.modules.mall.dao.MallSearchHistoryDao">

    <sql id="selectSql">
        SELECT
        T.ID,
        T.KEYWORD,
        T.FROM,
        T.ADD_TIME,
        T.USER_ID,
        WU.NICKNAME
        FROM MALL_SEARCH_HISTORY T LEFT JOIN WX_USER WU ON WU.ID = T.USER_ID
        WHERE 1=1
        <if test="params.id != null and params.id.trim() != ''">
            AND T.ID = #{params.id}
        </if>
        <if test="params.userId != null and params.userId != ''">
            AND T.USER_ID = #{params.userId}
        </if>
        <if test="params.from != null and params.from.trim() != ''">
            AND T.FROM = #{params.from}
        </if>
        <if test="params.keyword != null and params.keyword.trim() != ''">
            AND T.KEYWORD LIKE '%${params.keyword}%'
        </if>
    </sql>

    <select id="selectMallSearchHistoryPage" resultType="com.platform.modules.mall.entity.MallSearchHistoryEntity">
        <include refid="selectSql"/>
    </select>

    <select id="queryAll" resultType="com.platform.modules.mall.entity.MallSearchHistoryEntity">
        <include refid="selectSql"/>
    </select>

    <select id="queryList" resultType="com.platform.modules.mall.entity.MallSearchHistoryEntity">
        select
        <if test="fields != null and fields != ''">
            ${fields}
        </if>
        <if test="fields == null or fields == ''">
            *
        </if>
        from mall_search_history
        <where>
            <if test="userId != null">
                and user_id = #{userId}
            </if>
        </where>
        <choose>
            <when test="fields != null and fields != '' and fields.toLowerCase().contains('distinct')">
                order by keyword asc
            </when>
            <when test="sidx != null and sidx.trim() != ''">
                order by ${sidx} ${order}
            </when>
            <otherwise>
                order by id desc
            </otherwise>
        </choose>
        <if test="offset != null and limit != null">
            limit #{offset}, #{limit}
        </if>
    </select>

</mapper>

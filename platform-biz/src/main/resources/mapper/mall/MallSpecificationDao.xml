<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.platform.modules.mall.dao.MallSpecificationDao">

    <sql id="selectSql">
        SELECT
        T.ID,
        T.NAME,
        T.SORT_ORDER
        FROM MALL_SPECIFICATION T
        WHERE 1=1
        <if test="params.id != null and params.id.trim() != ''">
            AND T.ID = #{params.id}
        </if>
        <if test="params.name != null and params.name.trim() != ''">
            AND T.NAME LIKE '%${params.name}%'
        </if>
    </sql>

    <select id="selectMallSpecificationPage" resultType="com.platform.modules.mall.entity.MallSpecificationEntity">
        <include refid="selectSql"/>
    </select>

    <select id="queryAll" resultType="com.platform.modules.mall.entity.MallSpecificationEntity">
        <include refid="selectSql"/>
    </select>

    <select id="queryList" resultType="com.platform.modules.mall.entity.MallSpecificationEntity">
        select * from mall_specification
        <choose>
            <when test="sidx != null and sidx.trim() != ''">
                order by ${sidx} ${order}
            </when>
            <otherwise>
                order by id desc
            </otherwise>
        </choose>
        <if test="offset != null and limit != null">
            limit #{offset}, #{limit}
        </if>
    </select>

</mapper>

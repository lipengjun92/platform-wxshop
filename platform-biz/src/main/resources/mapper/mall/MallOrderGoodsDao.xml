<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.platform.modules.mall.dao.MallOrderGoodsDao">

    <sql id="selectSql">
        SELECT
        T.ID,
        T.ORDER_ID,
        T.GOODS_ID,
        T.GOODS_NAME,
        T.GOODS_SN,
        T.PRODUCT_ID,
        T.NUMBER,
        T.MARKET_PRICE,
        T.RETAIL_PRICE,
        T.GOODS_SPECIFITION_NAME_VALUE,
        T.IS_REAL,
        T.GOODS_SPECIFITION_IDS,
        T.LIST_PIC_URL
        FROM MALL_ORDER_GOODS T
        WHERE 1=1
        <if test="params.id != null and params.id.trim() != ''">
            AND T.ID = #{params.id}
        </if>
        <if test="params.orderId != null and params.orderId.trim() != ''">
            AND T.ORDER_ID = #{params.orderId}
        </if>
        <if test="params.goodsId != null and params.goodsId.trim() != ''">
            AND T.GOODS_ID = #{params.goodsId}
        </if>
        <if test="params.goodsName != null and params.goodsName.trim() != ''">
            AND T.GOODS_NAME LIKE '%${params.goodsName}%'
        </if>
    </sql>

    <select id="selectMallOrderGoodsPage" resultType="com.platform.modules.mall.entity.MallOrderGoodsEntity">
        <include refid="selectSql"/>
    </select>

    <select id="queryAll" resultType="com.platform.modules.mall.entity.MallOrderGoodsEntity">
        <include refid="selectSql"/>
    </select>
</mapper>
